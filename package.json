{
  "name": "claude-code-hooks-usage-demo",
  "version": "1.0.0",
  "description": "Claude Code hooks usage demo with e-commerce data utilities and secret protection",
  "main": "dist/main.js",
  "scripts": {
    "setup": "npm install && node ./scripts/init-claude.js",
    "build": "tsc",
    "start": "npm run build && node dist/main.js",
    "dev": "tsx src/main.ts",
    "example": "tsx src/example.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "sdk": "tsx sdk.ts",
    "clean": "rm -rf dist",
    "lint": "echo \"Linting not configured\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "claude-code",
    "hooks",
    "security",
    "ecommerce",
    "sqlite",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.5",
    "@tootallnate/once": "^3.0.1",
    "@types/node": "^24.0.13",
    "better-sqlite3": "^9.2.2",
    "brace-expansion": "^5.0.6",
    "tar": "^7.5.13",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
