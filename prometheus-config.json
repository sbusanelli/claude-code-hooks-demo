{
  "mcpServers": {
    "mcp-server": {
      "command": "cd /Users/sbusan01/angular/mcp-server && node dist/index.js",
      "args": [],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "prometheus": {
    "port": 9090,
    "endpoint": "/metrics",
    "metrics": [
      {
        "name": "mcp_server_uptime",
        "type": "gauge",
        "help": "Uptime of MCP server in seconds"
      },
      {
        "name": "mcp_server_requests_total",
        "type": "counter",
        "help": "Total number of MCP requests"
      },
      {
        "name": "mcp_server_request_duration_seconds",
        "type": "histogram",
        "help": "Duration of MCP requests in seconds"
      },
      {
        "name": "mcp_server_active_connections",
        "type": "gauge",
        "help": "Number of active MCP connections"
      },
      {
        "name": "mcp_server_errors_total",
        "type": "counter",
        "help": "Total number of MCP server errors"
      },
      {
        "name": "user_registrations_total",
        "type": "counter",
        "help": "Total number of user registrations"
      },
      {
        "name": "user_login_attempts_total",
        "type": "counter",
        "help": "Total number of login attempts"
      },
      {
        "name": "user_login_success_total",
        "type": "counter",
        "help": "Total number of successful logins"
      },
      {
        "name": "user_database_size",
        "type": "gauge",
        "help": "Number of users in database"
      },
      {
        "name": "api_requests_total",
        "type": "counter",
        "help": "Total number of HTTP API requests"
      },
      {
        "name": "api_request_duration_seconds",
        "type": "histogram",
        "help": "Duration of HTTP API requests in seconds"
      }
    ]
  }
}
